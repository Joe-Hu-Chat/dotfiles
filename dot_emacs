;;; Useful shortcut to scroll back and forth
(defun scroll-up-keep-cursor ()
  "Scroll up without moving cursor."
  (interactive)
  (scroll-up 1))

(defun scroll-down-keep-cursor ()
  "Scroll down without moving cursor."
  (interactive)
  (scroll-down 1))

(global-set-key (kbd "M-n") 'scroll-up-keep-cursor)
(global-set-key (kbd "M-p") 'scroll-down-keep-cursor)

;;; Unset and Rebind scrolling keybinding in markdown mode
(with-eval-after-load 'markdown-mode
     (define-key markdown-mode-map (kbd "M-n") nil)
     (define-key markdown-mode-map (kbd "M-n") 'scroll-up-keep-cursor)
     (define-key markdown-mode-map (kbd "M-p") nil)
     (define-key markdown-mode-map (kbd "M-p") 'scroll-down-keep-cursor))

;;; Backup key bindings for scrolling up and down
(global-set-key (kbd "C-,") 'scroll-up-keep-cursor)
(global-set-key (kbd "C-.") 'scroll-down-keep-cursor)
